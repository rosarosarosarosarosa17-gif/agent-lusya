# Пример файла окружения. Скопируйте в .env и впишите реальные значения.
# Сам .env в git не попадает (он в .gitignore).

# Имя агента
AGENT_NAME=moy-agent
# Интервал тика в миллисекундах
TICK_MS=10000
# Порт HTTP-сервера агента (/health, /task)
PORT=

# Supabase (память агента): базовый URL проекта и anon-ключ
SUPABASE_URL=
SUPABASE_KEY=

# Polza AI (мозг агента): ключ доступа к API
POLZA_API_KEY=

# Telegram-бот: токен от @BotFather
TELEGRAM_TOKEN=
# Telegram: id чата для уведомлений надзора (узнать через @userinfobot)
TELEGRAM_CHAT_ID=

# (необязательно) HTTP-прокси, если прямой доступ к Telegram закрыт.
# Пример: http://127.0.0.1:10809
# HTTPS_PROXY=
